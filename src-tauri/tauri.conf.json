{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Icon Sizes",
  "version": "1.1.1",
  "identifier": "com.iconsizes.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Icon Sizes - Cross Platform Icon Generator",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Generate app icons for multiple platforms",
    "longDescription": "A cross-platform icon generator that creates icons for Android, iOS, Chrome Extension, and more.",
    "macOS": {
      "signingIdentity": "Apple Development: 894985722@qq.com (74NN3NSTYN)",
      "notarization": {
        "appleSecurityTeamId": "74NN3NSTYN",
        "appleApi": {
          "issuer": { "env": "APPLE_API_ISSUER" },
          "key": { "env": "APPLE_API_KEY_PATH" },
          "keyId": { "env": "APPLE_API_KEY_ID" }
        }
      }
    }
  },
  "plugins": {
    "dialog": null,
    "fs": null,
    "opener": null,
    "notification": null
  }}
