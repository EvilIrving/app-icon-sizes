{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Icon Maker",
  "version": "1.0.0",
  "identifier": "com.iconmaker.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Icon Maker - Cross Platform Icon Generator",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Generate app icons for multiple platforms",
    "longDescription": "A cross-platform icon generator that creates icons for Android, iOS, Chrome Extension, and more."
  },
  "plugins": {
    "dialog": null,
    "fs": null,
    "opener": null,
    "notification": null
  }
}
